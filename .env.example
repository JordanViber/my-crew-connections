# My Crew Connections local environment example
#
# Preferred workflow:
# 1. start the local Supabase stack for this machine
# 2. run scripts/supabase-sync-env.ps1 on Windows or scripts/supabase-sync-env.sh on macOS/Linux
# 3. let the script write the correct client/.env.local for the current machine
#
# The local API URL is stable by default. The anon and service role keys should
# come from `supabase status -o env` instead of being copied manually across machines.
#
# This file remains an example at the repo root. The Next.js app reads from client/.env.local.

# Local Supabase URLs and public keys
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-local-anon-or-publishable-key

# Server-side only. Only needed once privileged server-side features exist.
SUPABASE_SERVICE_ROLE_KEY=replace-with-local-service-role-key

# Billing
STRIPE_SECRET_KEY=replace-with-stripe-secret-or-restricted-key
STRIPE_PREMIUM_PRODUCT_ID=prod_UNYDgrpXLyEEWO
STRIPE_PREMIUM_MONTHLY_PRICE_ID=price_1TRXutKjuEm9woaeA2HsHmkn
STRIPE_PREMIUM_YEARLY_PRICE_ID=price_1TReLpKjuEm9woae6nWqASQP
STRIPE_PREMIUM_MONTHLY_PAYMENT_LINK_URL=https://buy.stripe.com/4gM3cw6Lp4C66lD2DjbjW00
STRIPE_PREMIUM_YEARLY_PAYMENT_LINK_URL=https://buy.stripe.com/8x27sM7Ptd8CdO54LrbjW02

# PWA push notifications
NEXT_PUBLIC_VAPID_PUBLIC_KEY=replace-with-vapid-public-key
VAPID_PRIVATE_KEY=replace-with-vapid-private-key
VAPID_SUBJECT=mailto:you@example.com
CRON_SECRET=replace-with-random-cron-secret

# If using Colima on macOS, Supabase commands may need:
# DOCKER_HOST=unix://$HOME/.colima/default/docker.sock
