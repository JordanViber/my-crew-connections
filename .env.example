# My Crew Connections local environment example
# Copy to .env.local once the app is scaffolded.

# Local Supabase URLs and public keys
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-local-anon-or-publishable-key

# Server-side only
SUPABASE_SERVICE_ROLE_KEY=replace-with-local-service-role-key

# If using Colima on this machine, local Supabase commands may need:
# DOCKER_HOST=unix:///tmp/colima-docker.sock
